# Ignore everything not needed for Docker builds
.git
.github
.venv
.turbo
__pycache__
*.spec
docs
scripts
verify_*.py

# Environment files — NEVER bake secrets into images
**/.env
**/.env.*
**/.env.local

# Desktop/Frontend aren't needed for web or backend Docker builds
apps/desktop
apps/frontend

# Build artifacts
apps/web/.next
apps/backend/dist
node_modules

# Misc
*.md
.gitignore
