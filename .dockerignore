# Ignore everything not needed for Docker builds
.git
.github
.venv
.turbo
__pycache__
*.spec
docs
scripts
verify_*.py

# Environment files — NEVER bake secrets into images
**/.env
**/.env.*
**/.env.local

# Desktop source not needed, but keep package.json for workspace resolution
apps/desktop
!apps/desktop/package.json

# Build artifacts
apps/web/.next
apps/frontend/.next
apps/backend/dist
**/node_modules

# Misc
*.md
.gitignore
