{
  "name": "rabbit-hole-os",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:electron\" \"npm run dev:backend\"",
    "dev:frontend": "cd apps/frontend && npm run dev",
    "dev:electron": "cd apps/desktop && npm run dev",
    "dev:backend": "cd apps/backend && python -m uvicorn app.main:app --reload"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "turbo": "^1.11.2"
  }
}