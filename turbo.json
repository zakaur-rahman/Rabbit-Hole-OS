{
    "$schema": "https://turbo.build/schema.json",
    "pipeline": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [
                "dist/**",
                ".next/**",
                "!.next/cache/**",
                "build/**",
                "out/**"
            ],
            "env": ["NODE_ENV", "NEXT_PUBLIC_*"]
        },
        "lint": {
            "outputs": [],
            "inputs": [
                "**/*.ts",
                "**/*.tsx",
                "**/*.js",
                "**/*.jsx",
                "**/*.mjs",
                "eslint.config.*",
                ".eslintrc*",
                "tsconfig.json"
            ]
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "outputs": ["tsconfig.tsbuildinfo"],
            "inputs": [
                "**/*.ts",
                "**/*.tsx",
                "tsconfig.json",
                "tsconfig.*.json"
            ]
        },
        "test": {
            "dependsOn": ["build"],
            "outputs": ["coverage/**"],
            "inputs": [
                "src/**/*.tsx",
                "src/**/*.ts",
                "test/**/*.ts"
            ]
        },
        "dist": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    },
    "globalEnv": [
        "TURBO_DAEMON",
        "TURBO_TELEMETRY_DISABLED",
        "CI"
    ]
}