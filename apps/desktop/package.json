{
    "name": "Cognode",
    "version": "1.0.0",
    "main": "build/electron/main.js",
    "scripts": {
        "dev": "tsc && electron .",
        "build": "tsc",
        "start": "electron .",
        "dist": "tsc && electron-builder"
    },
    "build": {
        "appId": "com.cognode.app",
        "productName": "Cognode",
        "directories": {
            "output": "dist"
        },
        "files": [
            "build/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "../frontend/out",
                "to": "frontend"
            }
        ],
        "win": {
            "target": [
                "nsis"
            ],
            "extraResources": [
                {
                    "from": "../backend/dist/cognode-backend.exe",
                    "to": "bin/cognode-backend.exe"
                }
            ]
        },
        "mac": {
            "target": [
                "dmg",
                "zip"
            ],
            "category": "public.app-category.productivity",
            "extraResources": [
                {
                    "from": "../backend/dist/cognode-backend",
                    "to": "bin/cognode-backend"
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.8",
        "@types/node": "^20.0.0",
        "better-sqlite3": "^9.2.2",
        "electron": "^40.0.0",
        "electron-builder": "^26.0.12",
        "electron-rebuild": "^3.2.9",
        "typescript": "^5.3.0"
    }
}