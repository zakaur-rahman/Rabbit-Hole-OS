{
    "name": "rabbit-hole-os-desktop",
    "version": "0.1.0",
    "main": "build/electron/main.js",
    "scripts": {
        "dev": "tsc && electron .",
        "build": "tsc",
        "start": "electron .",
        "dist": "tsc && electron-builder"
    },
    "build": {
        "appId": "com.rabbithole.os",
        "productName": "RabbitHole OS",
        "directories": {
            "output": "dist"
        },
        "files": [
            "build/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "../backend/dist/rabbit-hole-backend.exe",
                "to": "bin/rabbit-hole-backend.exe"
            },
            {
                "from": "../frontend/out",
                "to": "frontend"
            }
        ],
        "win": {
            "target": [
                "nsis"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "electron": "28.0.0",
        "electron-builder": "26.0.12",
        "typescript": "^5.3.0"
    }
}