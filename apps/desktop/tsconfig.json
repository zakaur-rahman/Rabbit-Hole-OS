{
    "compilerOptions": {
        "target": "ESNext",
        "module": "commonjs",
        "strict": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./build",
        "rootDir": "./",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@rabbit-hole-os/shared-types": [
                "../../packages/shared-types/src"
            ]
        },
        "types": [
            "node"
        ]
    },
    "include": [
        "electron/**/*",
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}